# OpenAI — required for LLM annotation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# ElevenLabs — required to start; leave empty to fall back to local Qwen TTS
ELEVENLABS_API_KEY=

# Django
SECRET_KEY=dev-secret-key-change-in-prod
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Max upload / pasted-text size in megabytes
MAX_UPLOAD_MB=50

# PostgreSQL database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=reader
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
